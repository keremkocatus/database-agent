# .env örneği. Kopyala → .env (gitignore'da). Gerçek şifreleri buraya koy.

# Postgres (indeks/durum katmanı) — docker-compose ile uyumlu
DATABASE_URL=postgresql+asyncpg://dbagent:dbagent@localhost:5432/dbagent

# Lokal disk store kökü
DATA_DIR=data

# Çözümlenmiş config yolu
CONFIG_PATH=config/servers.yaml

# Seed/demo MSSQL salt-okunur servis hesabı (docker-compose seed ile kurulur)
DEMO_USER=svc_catalog_ro
DEMO_PASS=Demo_Catalog_ro_2026!

# Serving auth (M6+); şimdilik opsiyonel
# API_KEY=change-me

# --- M3: cloud provider anahtarları (allow_cloud: true ise) ---
# servers.yaml'da api_key_env bu adları işaret eder
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# Vertex: google-auth (gcloud auth application-default login) + project config
